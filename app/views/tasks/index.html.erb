<div class="max-w-4xl mx-auto mt-10">
    <h1 class="text-3xl font-bold mb-6">All Tasks</h1>
    
    <div class="flex gap-4 mb-6">
      <%= link_to "Create New Task", new_task_path, class: "bg-green-500 text-white px-4 py-2 rounded shadow hover:bg-green-600 font-bold" %>
      <%= link_to "Register a User", new_user_path, class: "bg-purple-500 text-white px-4 py-2 rounded shadow hover:bg-purple-600 font-bold" %>
    </div>
  
    <div class="grid gap-4 mt-6">
      <% @tasks.each do |task| %>
        <div class="border p-4 rounded shadow bg-white">
          <h2 class="text-xl font-bold"><%= task.name %></h2>
          <p class="text-gray-600"><%= task.description %></p>
          
          <div class="mt-4 flex gap-4 text-sm font-bold">
            <span class="text-blue-500">Status: <%= task.status %></span>
            
            <span class="text-purple-500">Assigned to: <%= task.user&.name %></span>
          </div>
        </div>
      <% end %>
    </div>
  </div>