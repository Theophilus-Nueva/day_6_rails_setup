<div class="w-md mx-auto mt-10">

    <%= link_to "← Back to Tasks", tasks_path, class: "text-gray-500 hover:text-gray-800 mb-6 inline-block font-bold" %>

    <h1 class="text-3xl font-bold mb-6">Create a New Task</h1>

      <% if @task.errors.any? %>
        <div class="bg-red-100 text-red-700 p-4 rounded mb-4">
          <ul class="list-disc ml-5">
            <% @task.errors.full_messages.each do |error| %>
              <li><%= error %></li>
            <% end %>
          </ul>
        </div>
      <% end %>
  
    <%= form_with model: @task, class: "flex flex-col gap-4" do |form| %>
      
      <div>
        <%= form.label :name, class: "font-bold" %>
        <%= form.text_field :name, class: "border p-2 w-full rounded" %>
      </div>
  
      <div>
        <%= form.label :description, class: "font-bold" %>
        <%= form.text_area :description, class: "border p-2 w-full rounded" %>
      </div>
  
      <div>
        <%= form.label :status, class: "font-bold" %>
        <%= form.select :status, ["In Progress", "For Review", "Completed"], {}, class: "border p-2 w-full rounded" %>
      </div>
  
      <div>
        <%= form.label :user_id, "Assign To:", class: "font-bold" %>
        <%= form.collection_select :user_id, User.all, :id, :name, { prompt: "Select a User" }, class: "border p-2 w-full rounded" %>
      </div>
  
      <%= form.submit "Save Task", class: "bg-blue-500 text-white font-bold py-2 px-4 rounded cursor-pointer mt-4" %>
      
    <% end %>
  </div>